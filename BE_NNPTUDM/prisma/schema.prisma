// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  username        String?   @unique
  email           String    @unique
  password        String
  firstName       String?
  lastName        String?
  avatar          String?
  isVerified      Boolean   @default(false)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())
  role            Role      @default(USER)

  refreshTokens RefreshToken[]
  cart          Cart?
  orders        Order[]
  cartItems     CartItem[]

  @@map("users")
}

model Product {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name        String
  description String?  @db.Text
  production  Int
  brandId     BigInt   @db.UnsignedBigInt
  categoryId  Int
  createdAt   DateTime @default(now())

  brand       Brand    @relation(fields: [brandId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])

  variants   ProductVariant[]
  images     ProductImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([name, production, brandId, categoryId])
  @@map("products")
}

model Cart {
  id        BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt     @unique @db.UnsignedBigInt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id               BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId           BigInt   @db.UnsignedBigInt
  productId        BigInt   @db.UnsignedBigInt
  productVariantId BigInt   @db.UnsignedBigInt
  quantity         Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id])
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  orderItems     OrderItem[]
  cart           Cart?          @relation(fields: [cartId], references: [id])
  cartId         BigInt?        @db.UnsignedBigInt

  @@unique([userId, productVariantId])

  @@map("cart_items")

}

model Order {
  id            BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  orderCode     String        @unique
  userId        BigInt        @db.UnsignedBigInt
  totalQuantity Int
  totalAmount   Decimal       @db.Decimal(12, 2)
  shippingFee   Decimal       @default(30000) @db.Decimal(12, 2)
  grandTotal    Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  addressLine   String
  ward          String
  city          String
  status        OrderStatus   @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model OrderItem {
  id               BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  orderId          BigInt   @db.UnsignedBigInt
  cartItemId       BigInt?  @db.UnsignedBigInt
  productId        BigInt   @db.UnsignedBigInt
  productVariantId BigInt   @db.UnsignedBigInt
  quantity         Int
  price            Decimal  @db.Decimal(12, 2)
  productName      String
  variantName      String?
  imageUrl         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "fk_orderitem_order")
  cartItem       CartItem?      @relation(fields: [cartItemId], references: [id], onDelete: SetNull, map: "fk_orderitem_cartitem")
  product        Product        @relation(fields: [productId], references: [id])
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@map("order_items")

}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  cod
  bank_transfer
  momo
  vnpay
}

model Brand {
  id   BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  name String  @unique
  slug String?

  products Product[]

  @@map("brands")
}

model Category {
  id   Int     @id @default(autoincrement())
  name String  @unique
  slug String?

  products Product[]

  @@map("categories")
}

model ProductVariant {
  id        BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  productId BigInt  @db.UnsignedBigInt
  capacity  Int
  price     Decimal @db.Decimal(10, 2)
  quantity  Int     @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_variants")
}

model ProductImage {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  productId BigInt   @db.UnsignedBigInt
  url       String
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model RefreshToken {
  id        BigInt   @id @default(autoincrement())
  token     String   @unique
  userId    BigInt   @db.UnsignedBigInt
  userAgent String
  isRevoked Boolean? @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model Queue {
  id        Int      @id @default(autoincrement())
  type      String
  payload   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

